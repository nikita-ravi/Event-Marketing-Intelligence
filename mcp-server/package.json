{
  "name": "event-campaign-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Ticketmaster event discovery and campaign recommendations",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:manual": "tsx src/test-search.ts"
  },
  "keywords": [
    "mcp",
    "ticketmaster",
    "events",
    "marketing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitest/ui": "^4.1.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
